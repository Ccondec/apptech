# Copy to .env.local and fill in. All NEXT_PUBLIC_* vars are exposed to
# the browser at build time. Server-only secrets must NOT have that prefix.

# Supabase project (public — it's already in the JS bundle on the deployed site)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Master password for /admin/licencias. Used both as the password and as
# the HMAC secret that signs the superadmin session cookie.
SUPERADMIN_KEY=change-me

# Resend transactional emails
RESEND_API_KEY=re_...

# Site URL (used in password-reset redirects and elsewhere)
NEXT_PUBLIC_SITE_URL=https://tech.snelapp.com
